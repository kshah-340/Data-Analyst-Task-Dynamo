    "# =============================================================================\n",
    "# Process Wyscout Data (On‑ball Production)\n",
    "# =============================================================================\n",
    "wy = wyscout.copy()\n",
    "\n",
    "WY_META_COLS = [\n",
    "    \"wy_player_id\", \"wy_competition_id\", \"start_wy_season_id\",\n",
    "    \"end_wy_season_id\", \"wy_team_id\", \"src_grouped_position\",\n",
    "    \"player_name\", \"birth_date\", \"team_name\", \"competition_name\",\n",
    "    \"start_season_name\", \"end_season_name\", \"composite_season_label\",\n",
    "]\n",
    "WY_COUNT_COLS = [\"matches\", \"matches_in_start\", \"matches_coming_off\", \"minutes_played\", \"num_90s\"]\n",
    "WY_RATE_COLS = [c for c in wy.columns if c not in WY_META_COLS and c not in WY_COUNT_COLS]\n",
    "\n",
    "# Weighted average of rate columns by num_90s.\n",
    "def wy_weighted_avg(df):\n",
    "    weight = df[\"num_90s\"]\n",
    "    total_90s = weight.sum()\n",
    "    result = {}\n",
    "    for col in WY_RATE_COLS:\n",
    "        result[col] = (df[col] * weight).sum() / total_90s if total_90s > 0 else np.nan\n",
    "    return pd.Series(result)\n",
    "\n",
    "# Aggregate by player\n",
    "# include_groups=False is needed to avoid a FutureWarning about the group keys being included in the output\n",
    "wy_rates = wy.groupby(\"wy_player_id\").apply(wy_weighted_avg, include_groups=False).reset_index()\n",
    "wy_counts = (\n",
    "    wy.groupby(\"wy_player_id\")[WY_COUNT_COLS]\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"minutes_played\": \"wy_total_minutes\", \"num_90s\": \"wy_total_90s\"})\n",
    ")\n",
    "wy_meta = (\n",
    "    wy.groupby(\"wy_player_id\")\n",
    "    .agg(\n",
    "        player_name=(\"player_name\", \"first\"),\n",
    "        birth_date=(\"birth_date\", \"first\"),\n",
    "        team_name=(\"team_name\", \"first\"),\n",
    "        competition_name=(\"competition_name\", \"first\"),\n",
    "        composite_season_label=(\"composite_season_label\", \"first\"),\n",
    "        wy_position_codes=(\"src_grouped_position\", lambda x: \", \".join(sorted(x.dropna().unique()))),\n",
    "    )\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "wy_total = wy_meta.merge(wy_counts, on=\"wy_player_id\").merge(wy_rates, on=\"wy_player_id\")"
   ]
