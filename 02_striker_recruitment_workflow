    "# =============================================================================\n",
    "# Scoring Helpers\n",
    "# =============================================================================\n",
    "# Convert a series to percentile ranks (0–1). NaNs are placed at bottom\n",
    "def percentile_rank(series):\n",
    "    return series.rank(pct=True, na_option=\"bottom\")\n",
    "\n",
    "def weighted_category_score(df, metric_weights, invert=None):\n",
    "    \"\"\"\n",
    "    Compute a weighted percentile score for a category.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    df : DataFrame\n",
    "    metric_weights : dict {col: weight}\n",
    "    invert : set of column names where lower raw = better (time_to_505_around_90)\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    Series : weighted average of percentile ranks (0–1)\n",
    "    \"\"\"\n",
    "    if invert is None:\n",
    "        invert = set()\n",
    "    total_weight = sum(metric_weights.values())\n",
    "    score = pd.Series(0.0, index=df.index)\n",
    "\n",
    "    for col, weight in metric_weights.items():\n",
    "        if col not in df.columns:\n",
    "            print(f\"  Warning: '{col}' not found – skipping\")\n",
    "            continue\n",
    "        pct = percentile_rank(df[col])\n",
    "        if col in invert:\n",
    "            pct = 1 - pct\n",
    "        score += pct * (weight / total_weight)\n",
    "    return score"
   ]
  },
