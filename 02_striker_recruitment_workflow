    "# =============================================================================\n",
    "# Process SkillCorner GI Data (Off‑ball Movement)\n",
    "# =============================================================================\n",
    "gi_clean = gi[gi[\"gi_check_passed\"] == True].copy()     # as discussed in EDA notebook, we should only include rows where the GI check passed\n",
    "\n",
    "GI_SUM_COLS = [\n",
    "    \"minutes\", \"minutes_tip\", \"minutes_otip\",\n",
    "    \"offballrun_count_total\", \"offballrun_count\",\n",
    "    \"offballrun_count_shotwithin10s\", \"offballrun_count_goalwithin10s\",\n",
    "    \"offballrun_count_targeted\", \"offballrun_count_received\",\n",
    "    \"offballrun_count_abovehsr\", \"offballrun_count_penaltyarea\",\n",
    "    \"offballrun_count_dangerous\", \"offballrun_count_dangerous_targeted\",\n",
    "    \"offballrun_count_dangerous_received\",\n",
    "]\n",
    "\n",
    "# Aggregate totals per player\n",
    "gi_season = gi_clean.groupby(\"player_id\", as_index=False)[GI_SUM_COLS].sum()\n",
    "gi_season[\"player_name\"] = gi_clean.groupby(\"player_id\")[\"player_name\"].first().values\n",
    "\n",
    "# Weighted average run distance\n",
    "def weighted_avg_distance(group):\n",
    "    counts = group[\"offballrun_count\"]\n",
    "    distances = group[\"offballrun_avgdistance\"]\n",
    "    total_count = counts.sum()\n",
    "    if total_count == 0:\n",
    "        return np.nan\n",
    "    return (distances * counts).sum() / total_count\n",
    "\n",
    "# include_groups=False is needed to avoid a FutureWarning about the group keys being included in the output\n",
    "gi_season[\"offballrun_avgdistance\"] = (\n",
    "    gi_clean.groupby(\"player_id\")\n",
    "    .apply(weighted_avg_distance, include_groups=False)\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "# Minutes by position\n",
    "gi_pos_minutes = (\n",
    "    gi_clean.groupby([\"player_id\", \"position\"])[\"minutes\"]\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"minutes\": \"pos_minutes\"})\n",
    ")\n",
    "\n",
    "# Attacking minutes (CF/LF/RF/LW/RW/AM)\n",
    "gi_pos_minutes[\"is_attacking\"] = gi_pos_minutes[\"position\"].isin(ATTACKING_SK_POSITIONS)\n",
    "gi_attacking = (\n",
    "    gi_pos_minutes[gi_pos_minutes[\"is_attacking\"]]\n",
    "    .groupby(\"player_id\")[\"pos_minutes\"]\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"pos_minutes\": \"gi_attacking_minutes\"})\n",
    ")\n",
    "gi_season = gi_season.merge(gi_attacking, on=\"player_id\", how=\"left\")\n",
    "gi_season[\"gi_attacking_minutes\"] = gi_season[\"gi_attacking_minutes\"].fillna(0)\n",
    "\n",
    "# CF minutes (strictly centre forward)\n",
    "gi_cf_minutes = (\n",
    "    gi_pos_minutes[gi_pos_minutes[\"position\"] == \"CF\"]\n",
    "    .groupby(\"player_id\")[\"pos_minutes\"]\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"pos_minutes\": \"gi_cf_minutes\"})\n",
    ")\n",
    "gi_season = gi_season.merge(gi_cf_minutes, on=\"player_id\", how=\"left\")\n",
    "gi_season[\"gi_cf_minutes\"] = gi_season[\"gi_cf_minutes\"].fillna(0)"
