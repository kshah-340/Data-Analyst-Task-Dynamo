    "# =============================================================================\n",
    "# Process SkillCorner Physical Data (Athleticism & Work Rate)\n",
    "# =============================================================================\n",
    "\n",
    "cols_to_drop = [\n",
    "    'Time to Sprint post-COD',\n",
    "    'Time to Sprint',\n",
    "    'Time to HSR post-COD',\n",
    "    'Time to 505 around 180',\n",
    "    'Time to HSR'\n",
    "]\n",
    "physical = physical.drop(columns=cols_to_drop)  # per EDA notebook, drop replaceable high-missingness columns\n",
    "\n",
    "# Replace the 2.3% missing for \"Time to 505 around 90\" with the median among attacking players \n",
    "\n",
    "median_505 = physical[physical['Position'].isin(ATTACKING_SK_POSITIONS)]['Time to 505 around 90'].median()\n",
    "physical['Time to 505 around 90'] = (physical['Time to 505 around 90'].fillna(median_505))\n",
    "\n",
    "physical.columns = (\n",
    "    physical.columns\n",
    "    .str.strip()\n",
    "    .str.lower()\n",
    "    .str.replace(\" \", \"_\")\n",
    "    .str.replace(\"-\", \"_\")\n",
    ")\n",
    "phys_clean = physical[physical[\"physical_check_passed\"] == True].copy()  # as discussed in EDA notebook, we should only include rows where the physical check passed\n",
    "\n",
    "PHYS_META_COLS = [\n",
    "    \"player\", \"short_name\", \"player_id\", \"birthdate\", \"team\", \"team_id\",\n",
    "    \"match\", \"match_id\", \"date\", \"competition\", \"competition_id\",\n",
    "    \"season\", \"season_id\", \"competition_edition_id\",\n",
    "    \"position\", \"position_group\", \"physical_check_passed\",\n",
    "]\n",
    "PHYS_P90_COLS = [c for c in phys_clean.columns if c.endswith(\"_p90\") or c == \"m/min\"]\n",
    "\n",
    "PHYS_SUM_COLS = [\n",
    "    c for c in phys_clean.columns\n",
    "    if c not in PHYS_META_COLS\n",
    "    and c not in PHYS_P90_COLS\n",
    "]\n",
    "\n",
    "# Aggregate totals per player\n",
    "phys_season = phys_clean.groupby(\"player_id\", as_index=False)[PHYS_SUM_COLS].sum()\n",
    "phys_season[\"player_name\"] = phys_clean.groupby(\"player_id\")[\"player\"].first().values\n",
    "\n",
    "# Recompute per‑90 columns\n",
    "phys_season[\"minutes_played\"] = phys_season[\"minutes\"]\n",
    "p90_denom = phys_season[\"minutes\"] / 90\n",
    "for col in PHYS_SUM_COLS:\n",
    "    if col == \"minutes\":\n",
    "        continue\n",
    "    p90_col = col + \"_p90\"\n",
    "    if p90_col in phys_clean.columns:\n",
    "        phys_season[p90_col] = phys_season[col] / p90_denom\n",
    "\n",
    "# Recompute m/min\n",
    "if \"distance\" in phys_season.columns:\n",
    "    phys_season[\"m/min\"] = phys_season[\"distance\"] / phys_season[\"minutes\"]\n",
    "\n",
    "# Minutes by position\n",
    "phys_pos_minutes = (\n",
    "    phys_clean.groupby([\"player_id\", \"position\"])[\"minutes\"]\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"minutes\": \"pos_minutes\"})\n",
    ")\n",
    "\n",
    "# Attacking minutes\n",
    "phys_pos_minutes[\"is_attacking\"] = phys_pos_minutes[\"position\"].isin(ATTACKING_SK_POSITIONS)\n",
    "phys_attacking = (\n",
    "    phys_pos_minutes[phys_pos_minutes[\"is_attacking\"]]\n",
    "    .groupby(\"player_id\")[\"pos_minutes\"]\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"pos_minutes\": \"phys_attacking_minutes\"})\n",
    ")\n",
    "phys_season = phys_season.merge(phys_attacking, on=\"player_id\", how=\"left\")\n",
    "phys_season[\"phys_attacking_minutes\"] = phys_season[\"phys_attacking_minutes\"].fillna(0)\n",
    "\n",
    "# CF minutes\n",
    "phys_cf_minutes = (\n",
    "    phys_pos_minutes[phys_pos_minutes[\"position\"] == \"CF\"]\n",
    "    .groupby(\"player_id\")[\"pos_minutes\"]\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"pos_minutes\": \"phys_cf_minutes\"})\n",
    ")\n",
    "phys_season = phys_season.merge(phys_cf_minutes, on=\"player_id\", how=\"left\")\n",
    "phys_season[\"phys_cf_minutes\"] = phys_season[\"phys_cf_minutes\"].fillna(0)\n",
    "\n",
    "# Primary position (most minutes)\n",
    "primary_position = (\n",
    "    phys_pos_minutes.sort_values(\"pos_minutes\", ascending=False)\n",
    "    .drop_duplicates(subset=\"player_id\", keep=\"first\")\n",
    "    [[\"player_id\", \"position\"]]\n",
    "    .rename(columns={\"position\": \"primary_position\"})\n",
    ")\n",
    "phys_season = phys_season.merge(primary_position, on=\"player_id\", how=\"left\")"
   ]
