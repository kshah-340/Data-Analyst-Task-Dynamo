    "# =============================================================================\n",
    "# Merge All Sources and Apply Filters\n",
    "# =============================================================================\n",
    "# Convert ID columns to nullable integer type for consistent merging\n",
    "id_map[\"wy_player_id\"] = id_map[\"wy_player_id\"].astype(\"Int64\")\n",
    "id_map[\"sk_player_id\"] = id_map[\"sk_player_id\"].astype(\"Int64\")\n",
    "wy_total[\"wy_player_id\"] = wy_total[\"wy_player_id\"].astype(\"Int64\")\n",
    "gi_season[\"player_id\"] = gi_season[\"player_id\"].astype(\"Int64\")\n",
    "phys_season[\"player_id\"] = phys_season[\"player_id\"].astype(\"Int64\")\n",
    "\n",
    "# Map Wyscout IDs to SkillCorner IDs\n",
    "wy_with_sk = wy_total.merge(id_map, on=\"wy_player_id\", how=\"inner\")\n",
    "\n",
    "# Merge both SkillCorner sources\n",
    "sk_merged = gi_season.merge(\n",
    "    phys_season,\n",
    "    on=\"player_id\",\n",
    "    how=\"inner\",\n",
    "    suffixes=(\"_gi\", \"_phys\"),\n",
    ")\n",
    "\n",
    "# Average minutes from SK sources\n",
    "sk_merged[\"sk_minutes\"] = (sk_merged[\"minutes_gi\"] + sk_merged[\"minutes_phys\"]) / 2\n",
    "sk_merged[\"sk_attacking_minutes\"] = (sk_merged[\"gi_attacking_minutes\"] + sk_merged[\"phys_attacking_minutes\"]) / 2\n",
    "sk_merged[\"sk_cf_minutes\"] = (sk_merged[\"gi_cf_minutes\"] + sk_merged[\"phys_cf_minutes\"]) / 2\n",
    "\n",
    "# Merge all three datasets\n",
    "df = wy_with_sk.merge(\n",
    "    sk_merged,\n",
    "    left_on=\"sk_player_id\",\n",
    "    right_on=\"player_id\",\n",
    "    how=\"inner\",\n",
    ")\n",
    "\n",
    "# Apply base minutes filters (total and attacking)\n",
    "df[\"total_minutes\"] = df[\"wy_total_minutes\"]\n",
    "df[\"attacking_minutes\"] = df[\"sk_attacking_minutes\"]\n",
    "mask_total = df[\"total_minutes\"] >= MIN_TOTAL_MINUTES\n",
    "mask_attacking = df[\"attacking_minutes\"] >= MIN_ATTACKING_MINUTES\n",
    "df_filtered = df[mask_total & mask_attacking].copy()\n",
    "\n",
    "# CF minutes and percentage (use sk_minutes as denominator)\n",
    "df_filtered[\"cf_minutes\"] = df_filtered[\"sk_cf_minutes\"]\n",
    "df_filtered[\"pct_minutes_cf\"] = df_filtered[\"cf_minutes\"] / df_filtered[\"sk_minutes\"] * 100\n",
    "\n",
    "# Optional: require at least 90 CF minutes and 10% of total minutes at CF\n",
    "MIN_CF_MINUTES = 90\n",
    "MIN_PCT_CF_MINUTES = 10\n",
    "mask_cf = (df_filtered[\"cf_minutes\"] >= MIN_CF_MINUTES) & (df_filtered[\"pct_minutes_cf\"] >= MIN_PCT_CF_MINUTES)\n",
    "df_filtered = df_filtered[mask_cf].copy()\n",
    "\n",
    "# Percentage of attacking minutes (using sk_minutes)\n",
    "df_filtered[\"pct_minutes_in_attacking_role\"] = (df_filtered[\"attacking_minutes\"] / df_filtered[\"sk_minutes\"]).round(4) * 100\n",
    "\n",
    "# Drop redundant duplicate columns (those ending with \"_gi\" that also exist as \"_phys\")\n",
    "cols_to_drop = [c for c in df_filtered.columns if c.endswith(\"_gi\") and c.replace(\"_gi\", \"_phys\") in df_filtered.columns]\n",
    "df_filtered = df_filtered.drop(columns=cols_to_drop, errors=\"ignore\")\n",
    "\n",
    "print(f\"Players meeting minutes filters: {df_filtered['wy_player_id'].nunique()}\")"
   ]
