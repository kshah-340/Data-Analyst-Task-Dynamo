    "df_filtered[\"pct_production\"]  = percentile_rank(df_filtered[\"score_production\"])  * 100\n",
    "\n",
    "# Composite score (weighted average of category percentiles)\n",
    "total_category_weight = WEIGHT_ATHLETICISM + WEIGHT_MOVEMENT + WEIGHT_PRODUCTION\n",
    "df_filtered[\"score_composite\"] = (\n",
    "    df_filtered[\"pct_athleticism\"] * (WEIGHT_ATHLETICISM / total_category_weight)\n",
    "    + df_filtered[\"pct_movement\"]  * (WEIGHT_MOVEMENT    / total_category_weight)\n",
    "    + df_filtered[\"pct_production\"]* (WEIGHT_PRODUCTION  / total_category_weight)\n",
    ")\n",
    "df_filtered[\"pct_composite\"] = percentile_rank(df_filtered[\"score_composite\"]) * 100"
