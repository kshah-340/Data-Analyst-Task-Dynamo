    "# =============================================================================\n",
    "# Grid of 3×2 Radars (Slide Insert)\n",
    "# =============================================================================\n",
    "# Define slide‑specific colours (light background, slightly different ring)\n",
    "SLIDE_BG = \"#FFFFFF\"\n",
    "SLIDE_RING = \"#F5F5F5\"\n",
    "\n",
    "# Map each radar dimension to a colour for the parameter labels\n",
    "DIM_COLORS = {\n",
    "    \"Pace\": DYNAMO_ORANGE,\n",
    "    \"Agility\": DYNAMO_ORANGE,\n",
    "    \"Off-Ball\": GOLD,\n",
    "    \"Passing\": GOLD,\n",
    "    \"Shooting\": DYNAMO_DARK,\n",
    "    \"Dribbling\": DYNAMO_DARK,\n",
    "}\n",
    "\n",
    "def plot_radar_grid_insert(\n",
    "    df,\n",
    "    player_names,\n",
    "    radar_cols=RADAR_COLS,\n",
    "    player_col=PLAYER_COL,\n",
    "    top_n=6,\n",
    "    save_path=\"radar_grid_insert.png\",\n",
    "):\n",
    "    labels, _ = _resolve_cols(radar_cols)\n",
    "    players   = player_names[:top_n]\n",
    "    N_COLS, N_ROWS = 3, 2\n",
    "\n",
    "    radar = Radar(\n",
    "        labels,\n",
    "        [0] * len(labels),\n",
    "        [100] * len(labels),\n",
    "        round_int=[True] * len(labels),\n",
    "        num_rings=4,\n",
    "        ring_width=1,\n",
    "        center_circle_radius=1,\n",
    "    )\n",
    "\n",
    "    fig = plt.figure(figsize=(11.8, 5.0), dpi=200, facecolor=SLIDE_BG)\n",
    "\n",
    "    # Adjust margins: top/bottom leave room for player names + score text\n",
    "    gs = GridSpec(\n",
    "        N_ROWS, N_COLS, figure=fig,\n",
    "        top=0.90, bottom=0.05,\n",
    "        left=0.03, right=0.97,\n",
    "        hspace=0.45, wspace=0.12,\n",
    "    )\n",
    "\n",
    "    for i, name in enumerate(players):\n",
    "        row, col = divmod(i, N_COLS)\n",
    "\n",
    "        ax = fig.add_subplot(gs[row, col])\n",
    "        ax.set_aspect(\"equal\")\n",
    "        ax.set(xlim=(-radar.lim, radar.lim), ylim=(-radar.lim, radar.lim))\n",
    "        ax.set_facecolor(SLIDE_RING)\n",
    "        for spine in ax.spines.values():\n",
    "            spine.set_visible(False)\n",
    "        ax.tick_params(left=False, bottom=False, labelleft=False, labelbottom=False)\n",
    "\n",
    "        radar.draw_circles(ax=ax, facecolor=SLIDE_RING,\n",
    "                           edgecolor=\"#C8C8C8\", lw=0.5, alpha=1.0)\n",
    "\n",
    "        values = _get_values(df, name, radar_cols, player_col)\n",
    "        radar.draw_radar(\n",
    "            values, ax=ax,\n",
    "            kwargs_radar={\"facecolor\": DYNAMO_ORANGE, \"alpha\": 0.45},\n",
    "            kwargs_rings={\"facecolor\": DYNAMO_ORANGE, \"alpha\": 0.08},\n",
    "        )\n",
    "\n",
    "        label_artists = radar.draw_param_labels(\n",
    "            ax=ax, fontsize=9.5, fontweight=\"bold\", color=DYNAMO_DARK\n",
    "        )\n",
    "        for artist, label in zip(label_artists, labels):\n",
    "            artist.set_color(DIM_COLORS[label])\n",
    "\n",
    "        comp = _composite_score(df, name, player_col)\n",
    "        comp_str = f\"Score: {comp:.0f}\" if comp is not None else \"\"\n",
    "\n",
    "        ax.set_title(\n",
    "            f\"#{i+1}  {name}\",\n",
    "            fontsize=11.5, fontweight=\"bold\", color=DYNAMO_DARK, pad=14,\n",
    "        )\n",
    "        ax.text(\n",
    "            0.5, 1.002, comp_str,\n",
    "            transform=ax.transAxes,\n",
    "            ha=\"center\", va=\"bottom\",\n",
    "            fontsize=8.5, color=DYNAMO_MID, style=\"italic\",\n",
    "        )\n",
    "\n",
    "    plt.savefig(save_path, dpi=200, facecolor=SLIDE_BG, bbox_inches=\"tight\")\n",
    "    print(f\"Saved → {save_path}\")\n",
    "    plt.show()\n",
    "\n",
    "# Generate the grid plot\n",
    "plot_radar_grid_insert(shortlist_updated, shortlist_names)"
   ]
